{
  "profile": "shipments",
  "file": {
    "patterns": ["发货统计"]
  },
  "output": {
    "dir": "shipments",
    "format": "array"
  },
  "normalizer": {
    "strategy": "rowArray",
    "sheet": "first",
    "skipEmptyRows": true,
    "fields": [
      { "source": 0,  "target": "date",                    "transform": "string" },
      { "source": 1,  "target": "customer",               "transform": "string" },
      { "source": 2,  "target": "businessType",           "transform": "string" },
      { "source": 3,  "target": "salesperson",            "transform": "string" },
      { "source": 4,  "target": "documentNo",             "transform": "string" },
      { "source": 5,  "target": "productName",            "transform": "string" },
      { "source": 6,  "target": "spec",                   "transform": "string" },
      { "source": 7,  "target": "batchNo",                "transform": "string" },
      { "source": 8,  "target": "packageCount",           "transform": "float"  },
      { "source": 9,  "target": "shipmentQty",            "transform": "float"  },
      { "source": 10, "target": "shipmentTaxAmountBase",  "transform": "float"  },
      { "source": 11, "target": "invoicedQty",            "transform": "float"  },
      { "source": 12, "target": "invoiceAmount",          "transform": "float"  },
      { "source": 13, "target": "uninvoicedQty",          "transform": "float"  },
      { "source": 14, "target": "uninvoicedAmount",       "transform": "float"  },
      { "source": 15, "target": "receivedAmount",         "transform": "float"  },
      { "source": 16, "target": "uninvoicedAmountBase",   "transform": "float"  },
      { "source": 17, "target": "uncollectedAmount",      "transform": "float"  },
      { "source": 18, "target": "paymentTerm",            "transform": "string" },
      { "source": 19, "target": "regions.level1",         "transform": "string" },
      { "source": 20, "target": "regions.level2",         "transform": "string" },
      { "source": 21, "target": "regions.level3",         "transform": "string" },
      { "source": 22, "target": "regions.level4",         "transform": "string" }
    ],
    "skip": [
      { "field": "date", "match": "合 计" },
      { "field": "date", "match": "合计" }
    ],
    "derived": {
      "year":  { "from": "_raw.year",               "transform": "pass" },
      "month": { "from": "date",                    "transform": "parseMonthFromDate" }
    }
  }
}
