{
  "profile": "sales-salary",
  "file": {
    "patterns": ["考核工资", "业务员"]
  },
  "output": {
    "dir": "sales-salary",
    "format": "array"
  },
  "normalizer": {
    "strategy": "headerTable",
    "sheet": "all",
    "headerDetection": {
      "markerColumn": 0,
      "markerValue": "姓名"
    },
    "skipEmptyRows": true,
    "fields": [
      { "source": "姓名",         "target": "name",                  "transform": "string" },
      { "source": "完成额（万）", "target": "completedAmount",       "transform": "float"  },
      { "source": "大客户",       "target": "majorCustomerAmount",   "transform": "float"  },
      { "source": "总额",         "target": "totalAmount",           "transform": "float"  },
      { "source": "月任务量（万）", "target": "monthlyTargetAmount",  "transform": "float"  },
      { "source": "占比",         "target": "completionRatio",       "transform": "float"  },
      { "source": "工资标准",     "target": "salaryStandard",        "transform": "float"  },
      { "source": "工资",         "target": "salary",                "transform": "float"  }
    ],
    "skip": [
      { "field": "name", "isEmpty": true },
      { "field": "name", "contains": "财务" },
      { "field": "name", "contains": "制表" }
    ],
    "derived": {
      "year":       { "from": "_raw.year",  "transform": "pass" },
      "month":      { "from": "_sheet",     "transform": "parseMonthFromSheet" },
      "recordType": { "from": "name",       "transform": "recordTypeByName" }
    }
  }
}
