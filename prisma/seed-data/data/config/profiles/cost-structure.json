{
  "profile": "cost-structure",
  "file": {
    "patterns": ["成本汇总", "成本构成", "汇总成本"]
  },
  "output": {
    "dir": "cost-structure",
    "format": "standardRowsObject"
  },
  "normalizer": {
    "strategy": "costStructure",
    "sheet": "all",
    "classifySheets": true,
    "useGenericTable": true,
    "standardRows": {
      "enabled": true,
      "sheetFilter": {
        "checkHeaders": ["产品状态", "名称", "成本单价"]
      },
      "fields": [
        { "source": 0,  "target": "productStatus",                "transform": "string" },
        { "source": 1,  "target": "productName",                  "transform": "string" },
        { "source": 2,  "target": "workHours",                    "transform": "float"  },
        { "source": 3,  "target": "cost.rawMaterials",            "transform": "float"  },
        { "source": 4,  "target": "cost.packagingMaterials",      "transform": "float"  },
        { "source": 5,  "target": "cost.wage",                    "transform": "float"  },
        { "source": 6,  "target": "cost.directLaborSocialSecurity", "transform": "float"  },
        { "source": 7,  "target": "cost.directLaborWelfare",      "transform": "float"  },
        { "source": 8,  "target": "cost.auxiliaryLaborWage",      "transform": "float"  },
        { "source": 9,  "target": "cost.auxiliaryLaborSocialSecurity", "transform": "float"  },
        { "source": 10, "target": "cost.auxiliaryLaborWelfare",   "transform": "float"  },
        { "source": 11, "target": "cost.utilities",               "transform": "float"  },
        { "source": 12, "target": "cost.depreciationDirect",      "transform": "float"  },
        { "source": 13, "target": "cost.depreciationAuxiliary",   "transform": "float"  },
        { "source": 14, "target": "cost.otherManufacturingCost",  "transform": "float"  },
        { "source": 15, "target": "cost.manufacturingSubtotal",   "transform": "float"  },
        { "source": 16, "target": "inboundQuantity",              "transform": "float"  },
        { "source": 17, "target": "unitCost",                     "transform": "float"  }
      ],
      "skip": [
        { "field": "productName", "isEmpty": true },
        { "field": "productName", "equals": "名称" },
        { "field": "productName", "contains": "入库成品汇总表" },
        { "field": "productName", "contains": "成 本" },
        { "field": "productName", "contains": "合计" }
      ],
      "extraColumns": {
        "startIndex": 18,
        "prefix": "col_"
      }
    }
  }
}
